{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "camera=(self)"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/pay",
      "destination": "/index.html"
    },
    {
      "source": "/create",
      "destination": "/index.html"
    },
    {
      "source": "/wallet",
      "destination": "/index.html"
    },
    {
      "source": "/scenarios",
      "destination": "/index.html"
    },
    {
      "source": "/experimental/generate",
      "destination": "/index.html"
    },
    {
      "source": "/experimental/scan",
      "destination": "/index.html"
    }
  ]
}
