# Private site authentication. Both values are required in production.
SITE_PASSWORD=replace-with-a-private-site-password
SESSION_SECRET=replace-with-a-long-random-secret

# Durable 15-minute payment-link sessions used by the deployed API.
# Local `npm run api` uses in-memory sessions instead.
REDIS_URL=redis://replace-with-your-session-redis-url

# Optional durable collaboration. These VITE_ values are visible to the browser.
# Use the publishable/anon key only; never expose the service-role key.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=replace-with-your-publishable-key
